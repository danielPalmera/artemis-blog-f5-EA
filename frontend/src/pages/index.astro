---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const res = await fetch("http://localhost:3000/api/v1/posts");
const posts = await res.json();

function localImg(src: string) {
	return src.replace(/^https?:\/\/[^/]+\/images\//, `${base}/images/`);
}
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="./favicon.svg" />
		<link rel="icon" href="./favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>The Artemis Diary</title>

		<!-- SEO -->
		<meta name="description" content="Crónicas de la misión Artemis II: el regreso de la humanidad al espacio profundo." />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content="The Artemis Diary" />
		<meta property="og:description" content="Crónicas de la misión Artemis II: el regreso de la humanidad al espacio profundo." />
		<meta property="og:url" content={Astro.site} />
		<meta property="og:site_name" content="The Artemis Diary" />
		<meta property="og:image" content={`${Astro.site}images/f376f070-7bec-11ed-b7ad-4883e56a6764.jpg`} />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="The Artemis Diary" />
		<meta name="twitter:description" content="Crónicas de la misión Artemis II: el regreso de la humanidad al espacio profundo." />
		<meta name="twitter:image" content={`${Astro.site}images/f376f070-7bec-11ed-b7ad-4883e56a6764.jpg`} />
		<style>
			* { box-sizing: border-box; margin: 0; padding: 0; }
			body { font-family: sans-serif; background: #0a0a0f; color: #eee; padding: 2rem; }
			header { margin-bottom: 2rem; }
			h1 { font-size: 2rem; letter-spacing: 0.05em; }
			ul.grid {
				list-style: none;
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1.5rem;
			}
			article.card {
				background: #16161f;
				border-radius: 10px;
				overflow: hidden;
				transition: transform 0.2s, box-shadow 0.2s;
				display: flex;
				flex-direction: column;
				height: 100%;
			}
			article.card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.4); }
			article.card a { text-decoration: none; color: inherit; display: flex; flex-direction: column; height: 100%; }
			article.card figure img { width: 100%; aspect-ratio: 16/9; object-fit: cover; display: block; }
			.card-body { padding: 1rem; flex: 1; display: flex; flex-direction: column; gap: 0.4rem; }
			.card-title { font-size: 1rem; font-weight: 600; line-height: 1.4; }
			.card-meta { font-size: 0.75rem; color: #888; margin-top: auto; padding-top: 0.5rem; display: flex; gap: 0.25rem; }
			address { font-style: normal; }
		</style>
	</head>
	<body>
		<header>
			<h1>The Artemis Diary</h1>
		</header>
		<main>
			<ul class="grid" role="list">
				{posts.map((post: any) => (
					<li>
						<article class="card">
							<a href={`${base}/posts/${post.slug}`}>
								<figure>
									<img src={localImg(post.coverImage.src)} alt={post.coverImage.alt} />
								</figure>
								<div class="card-body">
									<h2 class="card-title">{post.title}</h2>
									<footer class="card-meta">
										<time datetime={post.publishedAt}>{post.publishedAt}</time>
										<span> · </span>
										<address rel="author">{post.author}</address>
									</footer>
								</div>
							</a>
						</article>
					</li>
				))}
			</ul>
		</main>
	</body>
</html>
