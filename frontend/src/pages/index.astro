---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import type { Post } from '../types/post';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const res = await fetch("http://localhost:3000/api/v1/posts");
const posts: Post[] = await res.json();

function localImg(src: string) {
	return src.replace(/^https?:\/\/[^/]+\/images\//, `${base}/images/`);
}
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
		<link rel="icon" href={`${base}/favicon.ico`} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>The Artemis Diary</title>

		<!-- SEO -->
		<meta name="description" content="Crónicas de la misión Artemis II: el regreso de la humanidad al espacio profundo." />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content="The Artemis Diary" />
		<meta property="og:description" content="Crónicas de la misión Artemis II: el regreso de la humanidad al espacio profundo." />
		<meta property="og:url" content={Astro.site} />
		<meta property="og:site_name" content="The Artemis Diary" />
		<meta property="og:image" content={`${Astro.site}images/artemis-mission.jpg`} />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="The Artemis Diary" />
		<meta name="twitter:description" content="Crónicas de la misión Artemis II: el regreso de la humanidad al espacio profundo." />
		<meta name="twitter:image" content={`${Astro.site}images/artemis-mission.jpg`} />
		<style>
			* { box-sizing: border-box; margin: 0; padding: 0; }
			body { font-family: sans-serif; background: #0a0a0f; color: #eee; padding: 2rem 2rem 4rem; }
			header { margin-bottom: 2rem; }
			h1 { font-size: 2rem; letter-spacing: 0.05em; }
			ul.grid {
				list-style: none;
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				grid-auto-rows: 260px;
				gap: 1.5rem;
			}
			ul.grid > li { min-height: 0; }
			ul.grid > li:first-child {
				grid-column: span 2;
				grid-row: span 2;
			}
			article.card {
				background: #16161f;
				border-radius: 10px;
				overflow: hidden;
				transition: transform 0.2s, box-shadow 0.2s;
				display: flex;
				flex-direction: column;
				height: 100%;
			}
			article.card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.4); }
			article.card a { text-decoration: none; color: inherit; display: flex; flex-direction: column; height: 100%; }
			article.card figure { flex: 1; min-height: 0; overflow: hidden; }
			article.card figure img { width: 100%; height: 100%; object-fit: cover; display: block; }
			.card-body { padding: 0.75rem 1rem; flex-shrink: 0; display: flex; flex-direction: column; gap: 0.3rem; }
			.card-title { font-size: 1rem; font-weight: 600; line-height: 1.4; }
			ul.grid > li:first-child .card-title { font-size: 1.4rem; }
			.card-meta { font-size: 0.75rem; color: #888; margin-top: 0.25rem; display: flex; gap: 0.25rem; }
			address { font-style: normal; }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<ul class="grid" role="list">
				{posts.map((post: Post) => (
					<li>
						<article class="card">
							<a href={`${base}/posts/${post.slug}`}>
								<figure>
									<img src={localImg(post.coverImage.src)} alt={post.coverImage.alt} />
								</figure>
								<div class="card-body">
									<h2 class="card-title">{post.title}</h2>
									<footer class="card-meta">
										<time datetime={post.publishedAt}>{post.publishedAt}</time>
										<span> · </span>
										<address rel="author">{post.author}</address>
									</footer>
								</div>
							</a>
						</article>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>
