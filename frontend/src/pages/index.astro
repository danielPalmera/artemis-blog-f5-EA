---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import Title from "../components/Title.astro";
import type { Post } from "../types/post";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const res = await fetch("http://localhost:3000/api/v1/posts");

const posts: Post[] = await res.json();

function localImg(src: string) {
  return src.replace(/^https?:\/\/[^/]+\/images\//, `${base}/images/`);
}
---

<BaseLayout
  title="The Artemis Diary"
  description="Crónicas de la misión Artemis II: el regreso de la humanidad al espacio profundo."
  ogImage={`${Astro.site}images/artemis-mission.jpg`}
>
  <main>
    <Title />
    <ul class="grid" role="list">
      {
        posts.map((post: Post, index: number) => (
          <li>
            <PostCard
              post={post}
              base={base}
              localImg={localImg}
              isFeatured={index === 0}
            />
          </li>
        ))
      }
    </ul>
  </main>
</BaseLayout>

<style>
  main {
    width: 100%;
  }

  ul.grid {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    ul.grid {
      grid-template-columns: repeat(3, 1fr);
      grid-auto-rows: 260px;
    }

    ul.grid > li:first-child {
      grid-column: span 2;
      grid-row: span 2;
    }
  }

  ul.grid > li {
    min-height: 0;
  }
</style>
