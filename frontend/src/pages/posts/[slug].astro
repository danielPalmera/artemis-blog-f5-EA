---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import HeaderPost from '../../components/HeaderPost.astro';
import type { Post } from '../../types/post';

export async function getStaticPaths() {
	const res = await fetch("http://localhost:3000/api/v1/posts");
	const posts: Post[] = await res.json();
	return posts.map((post: Post) => ({
		params: { slug: post.slug },
		props: { post, allPosts: posts },
	}));
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const { post, allPosts }: { post: Post; allPosts: Post[] } = Astro.props;

const firstTag = String(post.tags).split(',')[0].trim().toLowerCase();
const relatedPosts = allPosts
	.filter(p => p.slug !== post.slug && String(p.tags).split(',').map(t => t.trim().toLowerCase()).includes(firstTag))
	.slice(0, 3);

function localImg(src: string) {
	return src.replace(/^https?:\/\/[^/]+\/images\//, `${base}/images/`);
}
---

<BaseLayout
	title={`${post.title} · The Artemis Diary`}
	description={post.excerpt}
	ogType="article"
	ogImage={post.coverImage.src}
	ogImageAlt={post.coverImage.alt}
>
	<meta slot="head" name="author" content={post.author} />
	<meta slot="head" property="article:published_time" content={post.publishedAt} />
	<meta slot="head" property="article:author" content={post.author} />
	<meta slot="head" property="article:tag" content={post.tags} />
	<style is:global>
		.content { line-height: 1.8; font-size: 1rem; }
		.content h2 { font-size: 1.4rem; margin: 2rem 0 0.75rem; }
		.content h3 { font-size: 1.1rem; margin: 1.5rem 0 0.5rem; color: #ccc; }
		.content p { margin-bottom: 1rem; color: #ccc; }
	</style>
	
	<article>
		<div class="w-full lg:max-w-[760px] lg:mx-auto flex flex-col px-6 lg:px-0 py-8 lg:py-16">
			<HeaderPost post={post} base={base} />
			<section class="content" set:html={post.content} aria-label="Contenido del artículo" />
		</div>
	</article>
	<RelatedArticles posts={relatedPosts} base={base} />
	
</BaseLayout>
