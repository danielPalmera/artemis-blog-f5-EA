---
import type { Post } from "../types/post";
import base from "../utils/base";
import { localImg } from '../utils/images';
interface Props {
    post: Post;
} 
const { post } = Astro.props;
---

<header class="flex flex-col gap-6 pb-8 lg:pt-12 lg:pb-0 lg:px-0 lg:gap-8 ">
	<a class="label tracking-widest uppercase text-(--color-text-secondary) hover:text-(--color-text-primary)" href={`${base}/`}>← Back to stories</a>
	<figure class="w-full max-h-80 overflow-hidden">
		<img class="w-full h-120 object-cover" src={localImg(post.coverImage.src, base)} alt={post.coverImage.alt} />
	</figure>
	<h1 class="heading-h2 text-(--color-text)">{post.title}</h1>
	<footer class="label flex flex-col lg:flex-row lg:items-center gap-x-2 text-(--color-text-secondary)">
		<time class="uppercase" datetime={post.publishedAt}>
			{new Date(post.publishedAt + 'T12:00:00').toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
		</time>
		<span class="hidden lg:inline" aria-hidden="true">·</span>
		<span class="uppercase">{post.readingTime} min rea</span>
	</footer>
</header>