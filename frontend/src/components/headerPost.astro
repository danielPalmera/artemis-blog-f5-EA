---
import type { Post } from "../types/post";

interface Props {
	post: Post;
	base: string;
	localImg: (src: string) => string;
}

const { post, base, localImg } = Astro.props;
---

<header>
	<a class="font-medium leading-[120%] tracking-[1.6px] uppercase text-[length:var(--fs-label)] text-[color:var(--color-text-secondary)] hover:text-[color:var(--color-text-primary)]" href={`${base}/`}>← Back to stories</a>
	<figure class="w-full max-h-[480px] overflow-hidden">
		<img class="w-full h-[480px] object-cover" src={localImg(post.coverImage.src)} alt={post.coverImage.alt} />
	</figure>
	<h1 class="text-[length:var(--fs-heading-h2)]">{post.title}</h1>
	<footer class="meta">
		<time class="uppercase" datetime={post.publishedAt}>
			{new Date(post.publishedAt + 'T12:00:00').toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
		</time>
		<span aria-hidden="true">·</span>
		<span class="uppercase">{post.readingTime} min rea</span>
	</footer>
</header>

<style>

	.back:hover { color: #eee; }

	h1 { font-size: 2rem; line-height: 1.3; margin-bottom: 1rem; }

	.meta {
		display: flex;
		gap: 1rem;
		font-size: 0.8rem;
		color: #888;
		margin-bottom: 0.75rem;
		flex-wrap: wrap;
	}
</style>