---
import type { Post } from "../types/post";

interface Props {
	post: Post;
	base: string;
}

const { post, base} = Astro.props;
---



<header class="flex flex-col mb-[var(--space32)]  gap-[var(--space24)]">

	<a class="font-medium leading-[120%] tracking-[1.6px] uppercase text-[length:var(--fs-label)] text-[color:var(--color-text-secondary)] hover:text-[color:var(--color-text-primary)]" href={`${base}/`}>← Back to stories</a>

	<figure class="w-full max-h-[320px] overflow-hidden">
		<img class="w-full h-[480px] object-cover" src={post.coverImage.src} alt={post.coverImage.alt} />
	</figure>

	<h1 class="font-bold text-[length:var(--fs-heading-h2)] leading-[110%]">{post.title}</h1>

	<footer class="flex flex-col lg:flex-row lg:items-center leading-[1.3] gap-x-[var(--space8)] font-medium text-[length:var(--fs-label)] text-[color:var(--color-text-secondary)]">
		<time class="uppercase" datetime={post.publishedAt}>
			{new Date(post.publishedAt + 'T12:00:00').toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
		</time>
		<span class="hidden lg:inline" aria-hidden="true">·</span>
		<span class="uppercase">{post.readingTime} min rea</span>
	</footer>

</header>