---
import type { Post } from '../types/post';

interface Props {
	posts: Post[];
	base: string;
	localImg: (src: string) => string;
}

const { posts, base, localImg } = Astro.props;
---

<aside aria-label="Artículos relacionados">
	<header>
		<p class="label">CONTINUE READING</p>
		<h2>Related stories</h2>
	</header>
	<nav>
		<ul class="grid grid-3">
		{posts.map(relatedPost => (
			<li>
                <article style={`background-image: url('${localImg(relatedPost.coverImage.src)}')`}>
                    <a href={`${base}/posts/${relatedPost.slug}`}>
                        <div class="card-body">
                            <time datetime={relatedPost.publishedAt}>
                                {new Date(relatedPost.publishedAt + 'T12:00:00').toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                            </time>
                            <h2 class="card-title">
                                {relatedPost.title}
                            </h2>
                        </div>
                    </a>
                </article>
			</li>
		))}
		</ul>
	</nav>
</aside>

<style>
	aside > header {
		margin-bottom: var(--space-lg);
		border-top: 1px solid var(--color-border);
		padding-top: var(--space-lg);
	}

	.label {
		font-size: 0.875rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: #d4a574;
		margin-bottom: var(--space-sm);
		font-weight: 600;
	}

	h2 {
		font-size: 2rem;
		margin-bottom: var(--space-lg);
	}

	.grid-3 {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: var(--space-lg);
		list-style: none;
	}

	article {
		cursor: pointer;
		transition: transform 0.3s ease;
		background-size: cover;
		background-position: center;
		border-radius: 8px;
		overflow: hidden;
		aspect-ratio: 4/3;
		position: relative;
	}

	article::after {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(to top, rgba(0,0,0,0.85) 40%, rgba(0,0,0,0.1) 100%);
	}

	article:hover {
		transform: translateY(-4px);
	}

	article a {
		display: flex;
		align-items: flex-end;
		height: 100%;
		text-decoration: none;
		color: inherit;
		position: relative;
		z-index: 1;
	}

	.card-body {
		padding: 1rem;
	}

	.card-title {
		font-size: 1rem;
		line-height: 1.3;
		color: #fff;
		margin-top: 0.25rem;
	}

	time {
		font-size: 0.8rem;
		color: #ccc;
		display: block;
	}
</style>
