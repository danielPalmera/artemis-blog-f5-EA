---
import RelatedArticlesList from "../molecules/RelatedArticlesList.astro";
import type { Post } from "../../types/post";
import H3 from "../atoms/H3.astro";
import PreTitle from "../atoms/PreTitle.astro";
interface Props {
    posts: Post[];
}

const { posts } = Astro.props;
---

<aside aria-label="Artículos relacionados ">
	<header class="flex flex-col pt-12 pb-16 px-6 border-(--color-border) gap-2">
		<PreTitle type="related">CONTINUE READING</PreTitle>
		<H3 type="related">Related stories</H3>
	</header>
	<RelatedArticlesList posts={posts} />
</aside>
