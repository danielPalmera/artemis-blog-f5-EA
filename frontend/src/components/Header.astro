---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<header class="site-header py-[var(--space16)] px-[20px] flex items-center bg-[var(--color-header-bg)] border-b border-[var(--color-header-line)]">
    <a href={`${base}/`} aria-label="Ir al inicio">
        <img src={`${base}/images/artemis-logo.png`} class="h-10 w-auto" alt="The Artemis Diary" />
    </a>
</header>
