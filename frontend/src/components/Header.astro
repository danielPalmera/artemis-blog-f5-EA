---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<header
  class="py-[var(--space16)] px-[20px] flex items-center bg-[var(--color-header-bg)] border-b border-[var(--color-header-line)]"
>
  <div class="w-full lg:container lg:mx-auto lg:px-[var(--space64)]">
  <a
      href={`${base}/`}
      aria-label="Ir al inicio"
      class="
      focus-visible:outline
      focus-visible:outline-2
      focus-visible:outline-[var(--color-accent-blue)]
      focus-visible:outline-offset-4"
    >
      <img
        src={`${base}/images/artemis-logo.png`}
        class="h-10 w-auto"
        alt="The Artemis Diary"
      />
    </a>
  </div>
  
</header>
