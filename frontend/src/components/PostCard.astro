---
import type { Post } from "../types/post";
import base from "../lib/base";

interface Props {
  post: Post;
  isRelated?: boolean;
}

const { post, isRelated = false } = Astro.props;
---


<article class="rounded-xl h-full relative z-0 focus-within:z-10">
  <a
    href={`${base}/posts/${post.slug}`}
    aria-label={post.title}
    class="group relative block w-full h-full aspect-square no-underline text-inherit
          rounded-xl
          focus-visible:outline
          focus-visible:outline-offset-0
          focus-visible:outline-[var(--color-accent-blue)]"
  >
    <div class="absolute inset-0 rounded-xl overflow-hidden">
      <img
        class="absolute inset-0 w-full h-full object-cover block"
        src={post.coverImage.src}
        alt={post.coverImage.alt}
      />

      <div class="absolute inset-0 flex items-end bg-[linear-gradient(180deg,rgba(0,0,0,0.25)_0%,rgba(0,0,0,0.55)_50%,rgba(0,0,0,0.85)_100%)] opacity-100 transition-opacity duration-300">
        <div class={`p-8 flex flex-col gap-4 text-white w-full transition-[opacity,transform] duration-[350ms] ease-in-out ${isRelated ? '' : 'lg:opacity-0 lg:translate-y-3 lg:group-hover:opacity-100 lg:group-hover:translate-y-0'}`}>
          <time class="text-xs opacity-80 tracking-wide" datetime={post.publishedAt}>
            {new Date(post.publishedAt + "T12:00:00").toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </time>

          <h2 class="text-base font-bold leading-[1.35] m-0">{post.title}</h2>

          {!isRelated && (
            <>
              <p class="text-[0.85rem] opacity-[0.85] line-clamp-1 m-0">{post.excerpt}</p>
              <span class="text-[length:var(--fs-caption)] text-[var(--color-accent-gold)] font-medium mt-1 tracking-wide">Read story →</span>
            </>
          )}

        </div>
      </div>
    </div>
  </a> 
</article>