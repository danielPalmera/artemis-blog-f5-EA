---
import type { Post } from "../types/post";

interface Props {
  post: Post;
  base: string;
  isFeatured?: boolean;
}

const { post, base} = Astro.props;
---

<article class="card">
  <a
    href={`${base}/posts/${post.slug}`}
    class="block
    rounded-[10px]
    focus:outline
    focus:outline-2
    focus:outline-[var(--color-accent-blue)]
    focus:outline-offset-4"
  >
    <figure>
      <img
        src={post.coverImage.src}
        alt={post.coverImage.alt}
        loading="lazy"
      />
    </figure>

    <div class="card-body">
      <time datetime={post.publishedAt}>
        {
          new Date(post.publishedAt + "T12:00:00").toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })
        }
      </time>
      <h2
        class:list={[
          "card-title",
          "text-[var(--color-text)]"
        ]}
        
      >
        {post.title}
      </h2>
      <p class="line-clamp-1">{post.excerpt}</p>
      <span class="hidden lg:inline text-[var(color-text-muted)]"> Read story → </span>
    </div>
  </a>
</article>

<style>
  .card {
    background: #16161f;
    border-radius: 10px;
    overflow: visible;
    transition:
      transform 0.2s,
      box-shadow 0.2s;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
  }

  .card a {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .card figure {
    flex: 1;
    min-height: 0;
    overflow: hidden;
  }

  .card figure img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-body {
    /* padding: 0.75rem 1rem; */
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .card-title {
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.4;
  }

  .featured-title {
    font-size: 1.4rem;
  }

  .card-meta {
    font-size: 0.75rem;
    color: #888;
    margin-top: 0.25rem;
    display: flex;
    gap: 0.25rem;
  }

  address {
    font-style: normal;
  }
</style>
