---
interface Props {
    publishedAt: string;
}

const { publishedAt } = Astro.props;
---
<time class="caption uppercase tracking-wide" datetime={publishedAt}>
    {new Date(publishedAt + "T12:00:00").toLocaleDateString("en-US", {
        year: "numeric",
        month: "short",
        day: "numeric",
    })}
</time>