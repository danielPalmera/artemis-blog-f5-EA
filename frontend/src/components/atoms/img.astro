---
import { Image } from "astro:assets";
interface Props {
    src: string;
    alt: string;
    class: string;
    width?: number;
    height?: number;
}
const { src, alt, class: className, width=100, height=100 } = Astro.props;
---
<Image class={className} src={src} alt={alt} width={width} height={height}/>