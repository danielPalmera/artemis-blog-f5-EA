{
  "name": "artemis-blog",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:front": "pnpm --dir frontend dev",
    "dev:api": "pnpm --dir backend dev",
    "build": "pnpm --dir backend build",
    "build:api": "pnpm --dir backend build",
    "start": "pnpm --dir backend start",
    "preview": "pnpm build:api && pnpm --dir backend start",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  }
}
